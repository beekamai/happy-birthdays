PORT=8131
HOST=127.0.0.1
BASE_URL=https://hb.beekamai.com
NODE_ENV=production

# Telegram Login (admin). Create a bot in @BotFather, then:
#   /newbot      -> get the token below
#   /setdomain   -> set hb.beekamai.com for that bot
TG_BOT_TOKEN=
TG_BOT_USERNAME=
# Your Telegram @username (without @) — gets owner rights over all pages.
OWNER_TG_USERNAME=
# Long random string for signing session JWTs.
SESSION_SECRET=change-me-to-a-long-random-string
